{
  "name": "arsist-engine",
  "version": "1.0.0",
  "description": "Cross-Platform Development Engine for AR Glasses",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/main/main.js http://localhost:5173 && node scripts/dev-electron.mjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "npx electron .",
    "electron:dev": "concurrently \"npm run dev:main\" \"wait-on dist/main/main/main.js && electron .\" \"npm run dev:renderer\"",
    "package": "npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "xreal:diag": "node scripts/xreal-diag.js",
    "mcp:ir": "node scripts/mcp-ir-server.mjs",
    "verify:ir": "node scripts/verify-ir-consistency.js",
    "verify:mcp": "node scripts/mcp-ir-smoke.mjs",
    "verify:mcp:full": "node scripts/mcp-ir-full-test.mjs",
    "build:unity:test": "node scripts/run-unity-build.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@monaco-editor/react": "^4.6.0",
    "@pixiv/three-vrm": "^3.1.0",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.0",
    "archiver": "^6.0.1",
    "chokidar": "^3.5.3",
    "clsx": "^2.1.0",
    "cross-env": "^10.1.0",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "immer": "^11.1.3",
    "lucide-react": "^0.303.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-flow-renderer": "^10.3.17",
    "reactflow": "^11.10.1",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.160.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.1.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.arsist.engine",
    "productName": "Arsist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
